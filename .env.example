APP_NAME=CommerceBrain API
APP_DESCRIPTION=AI-Native Commerce Platform
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
LOG_JSON=false
LOG_FILE=backend/app.log
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

POSTGRES_DB=commercebrain
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=******postgres:5432/commercebrain

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

OPENAI_API_KEY=
GEMINI_API_KEY=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
